generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth Models ────────────────────────────────────────────────────────

model User {
  id                  String    @id
  name                String
  email               String    @unique
  emailVerified       Boolean   @default(false)
  image               String?
  role                String    @default("customer")
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  vendorProfile VendorProfile?
  cart          Cart?
  wishlist      Wishlist[]
  orders        Order[]     @relation("CustomerOrders")
  payments      Payment[]
  notifications Notification[]
  shippingAddresses ShippingAddress[]
  reviews           Review[]
  conversations     ConversationParticipant[]
  messages          Message[]
  stories           Story[]
  storyViews        StoryView[]
  wallet            Wallet?
  reelLikes         ReelLike[]
  reels             Reel[]
  buyerNegotiations PriceNegotiation[] @relation("BuyerNegotiations")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                      String    @id
  userId                  String
  accountId               String
  providerId              String
  accessToken             String?
  refreshToken            String?
  idToken                 String?
  accessTokenExpiresAt    DateTime?
  refreshTokenExpiresAt   DateTime?
  scope                   String?
  tokenType               String?
  password                String?
  expiresAt               DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ─── Vendor Models ──────────────────────────────────────────────────────────────

model VendorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopName    String
  slug        String   @unique
  description String?
  logo        String?
  banner      String?
  address     String?
  city        String?
  state       String?
  phone       String?
  isActive    Boolean  @default(true)

  farmSizeAcres   Decimal?
  farmingDistrict String?
  cropTypes       String[] @default([])
  isCooperative   Boolean  @default(false)

  totalEarnings Decimal @default(0)
  pendingPayout Decimal @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
  coupons     Coupon[]
  services    Service[]
  escrows     Escrow[]
}

// ─── Product Models ─────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?
  description String?
  isActive    Boolean  @default(true)

  products    Product[]

  @@index([slug])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Decimal
  stock       Int      @default(0)

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  vendorId    String?
  vendor      VendorProfile? @relation(fields: [vendorId], references: [id])

  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  isDeleted   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images          ProductImage[]
  wishlist        Wishlist[]
  orderItems      OrderItem[]
  cartItems       CartItem[]
  reviews         Review[]
  deliveryOptions Json          @default("[]")
  reels           Reel[]

  unit             ProduceUnit @default(KG)
  minOrderQuantity Int         @default(1)
  harvestDate      DateTime?
  shelfLifeDays    Int?
  isPerishable     Boolean     @default(true)
  farmLocationLat  Float?
  farmLocationLng  Float?

  negotiations    PriceNegotiation[]

  @@index([categoryId])
  @@index([vendorId])
  @@index([slug])
  @@index([isActive])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url         String
  isPrimary   Boolean  @default(false)
  order       Int      @default(0)

  @@index([productId])
}

model Wishlist {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Cart Models ─────────────────────────────────────────────────────────────────

model Cart {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       CartItem[]
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productName String
  price       Decimal
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
}

// ─── Order Models ────────────────────────────────────────────────────────────────

model Order {
  id              String          @id @default(cuid())
  orderNumber     String          @unique
  userId          String
  user            User            @relation("CustomerOrders", fields: [userId], references: [id], onDelete: Cascade)

  status          OrderStatus     @default(pending)
  subtotal        Decimal
  shippingFee     Decimal           @default(0)
  tax             Decimal           @default(0)
  total           Decimal

  paymentStatus   PaymentStatus   @default(pending)
  paymentMethod   String?
  paystackRef     String?

  shippingAddress ShippingAddress @relation(fields: [shippingAddressId], references: [id], onDelete: Cascade)
  shippingAddressId String        @unique

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           OrderItem[]
  payment         Payment?
  escrows         Escrow[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  productName String
  productSlug String
  price       Decimal
  quantity    Int
  total       Decimal
  imageUrl    String?

  @@index([orderId])
  @@index([productId])
}

model ShippingAddress {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName   String
  lastName    String
  phone       String
  email       String
  address     String
  city        String
  state       String
  zipCode     String?
  country     String    @default("Ghana")
  instructions String?

  order       Order?
}

// ─── Payment Model ───────────────────────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount          Decimal
  currency        String        @default("GHS")
  status          PaymentStatus @default(pending)
  paystackRef     String        @unique
  paystackTxRef   String?
  paymentMethod   String?
  channel         String?       // card, bank, ussd, mobile_money
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paystackRef])
}

// ─── Coupon Model ────────────────────────────────────────────────────────────────

model Coupon {
  id              String          @id @default(cuid())
  code            String          @unique
  vendorId        String?
  vendor          VendorProfile?  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  discountPercent Decimal
  minOrderAmount  Decimal           @default(0)
  maxUses         Int             @default(100)
  currentUses     Int             @default(0)
  isActive        Boolean         @default(true)
  expiresAt       DateTime
  createdAt       DateTime        @default(now())

  @@index([code])
  @@index([vendorId])
}

// ─── Notification Model ──────────────────────────────────────────────────────────

model Notification {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        NotificationType
  isRead      Boolean            @default(false)
  data        String?            // JSON string for additional data
  createdAt   DateTime           @default(now())

  @@index([userId])
  @@index([isRead])
}

// ─── Review Model ────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

// ─── Chat Models ────────────────────────────────────────────────────────

model Conversation {
  id        String    @id @default(cuid())
  orderId   String?   // Optional link to an order
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?    // When the user last read the conversation
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ─── Story Models ────────────────────────────────────────────────────────

model Story {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl  String   // Image or video URL
  caption   String?
  expiresAt DateTime // 24h from creation
  createdAt DateTime @default(now())

  views StoryView[]

  @@index([userId])
  @@index([expiresAt])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewerId String
  viewer   User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@unique([storyId, viewerId])
  @@index([storyId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────────

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

enum NotificationType {
  order
  payment
  shipping
  promotion
  system
  review
}

enum ProduceUnit {
  KG
  CRATE
  BASKET
  BAG
  TON
  PIECE
}

enum AgriVehicleType {
  ABOBOYAA_TRICYCLE
  PICKUP_TRUCK
  REFRIGERATED_VAN
  MINI_TRUCK
  HEAVY_TRUCK
}

enum NegotiationStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
}

model PriceNegotiation {
  id               String            @id @default(cuid())
  productId        String
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerId          String
  buyer            User              @relation("BuyerNegotiations", fields: [buyerId], references: [id], onDelete: Cascade)
  vendorId         String
  proposedPrice    Decimal
  proposedQuantity Int
  status           NegotiationStatus @default(PENDING)
  message          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([productId])
  @@index([buyerId])
  @@index([vendorId])
}

// ─── Wallet Models ────────────────────────────────────────────────────────

enum WalletStatus {
  ACTIVE
  FROZEN
  SUSPENDED
}

enum TransactionType {
  TOPUP
  WITHDRAWAL
  TRANSFER_SENT
  TRANSFER_RECEIVED
  ORDER_PAYMENT
  EARNINGS
  REVERSAL
  FEE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum MomoProvider {
  MTN
  VODAFONE
  AIRTELTIGO
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

model Wallet {
  id            String        @id @default(uuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id])
  balance       Decimal         @default(0)
  currency      String        @default("GHS")
  status        WalletStatus  @default(ACTIVE)
  pinHash       String?
  pinFailures   Int           @default(0)
  pinLockedUntil DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  transactions  Transaction[]
  bankAccounts  BankAccount[]
  momoAccounts  MomoAccount[]
  cards         Card[]
  escrowBuyer   Escrow[]      @relation("EscrowBuyer")
  escrowVendor  Escrow[]      @relation("EscrowVendor")
}

model Transaction {
  id                  String            @id @default(uuid())
  walletId            String
  wallet              Wallet            @relation(fields: [walletId], references: [id])
  type                TransactionType
  status              TransactionStatus @default(PENDING)
  amount          Decimal
  fee                 Decimal             @default(0)
  netAmount           Decimal
  currency            String            @default("GHS")
  reference           String            @unique
  providerRef         String?
  description         String?
  metadata            Json?
  counterpartyWalletId String?           // other wallet involved (transfers)
  reversedById        String?            // if reversal, ref to original tx id
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([walletId, createdAt])
  @@index([reference])
}

model BankAccount {
  id                    String   @id @default(uuid())
  walletId              String
  wallet                Wallet   @relation(fields: [walletId], references: [id])
  bankName              String
  bankCode              String
  accountNumber         String
  accountName           String
  paystackRecipientCode String?
  isDefault             Boolean  @default(false)
  isVerified            Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@unique([walletId, accountNumber])
}

model MomoAccount {
  id          String       @id @default(uuid())
  walletId    String
  wallet      Wallet       @relation(fields: [walletId], references: [id])
  provider    MomoProvider @default(MTN)
  phoneNumber String
  accountName String
  isDefault   Boolean      @default(false)
  isVerified  Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@unique([walletId, phoneNumber])
}

model Card {
  id                String   @id @default(uuid())
  walletId          String
  wallet            Wallet   @relation(fields: [walletId], references: [id])
  cardholderName    String?
  type              String
  last4             String
  expiryMonth       String
  expiryYear        String
  isDefault         Boolean  @default(false)
  authorizationCode String?
  bin               String?
  bank              String?
  createdAt         DateTime @default(now())

  @@index([walletId])
}

// ─── Escrow Model ──────────────────────────────────────────────────────────────

model Escrow {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendorId        String?
  vendor          VendorProfile? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  buyerWalletId   String
  buyerWallet     Wallet        @relation("EscrowBuyer", fields: [buyerWalletId], references: [id])
  vendorWalletId  String?
  vendorWallet    Wallet?       @relation("EscrowVendor", fields: [vendorWalletId], references: [id], onDelete: SetNull)
  amount          Decimal
  commission      Decimal         @default(0)
  netAmount       Decimal
  status          EscrowStatus  @default(HELD)
  heldAt          DateTime      @default(now())
  releasedAt      DateTime?
  refundedAt      DateTime?
  releasedTxnId   String?
  refundedTxnId   String?
  reason          String?       // Why released/refunded/disputed
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([vendorId])
  @@index([status])
  @@index([buyerWalletId])
}

model PlatformConfig {
  id                   String   @id @default(uuid())
  commissionRate       Decimal    @default(0.05)
  taxRate              Decimal    @default(0.075)
  withdrawalFeeFlat    Decimal    @default(2.00)
  minTopup             Decimal    @default(5.00)
  maxTopup             Decimal    @default(5000.00)
  minWithdrawal        Decimal    @default(10.00)
  dailyWithdrawalLimit Decimal    @default(5000.00)
  updatedAt            DateTime @updatedAt
}

// ─── Reel Model ────────────────────────────────────────────────────────────────

model Reel {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoUrl    String
  thumbnailUrl String?
  caption     String?
  productId   String?  // Optional linked product
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  likesCount  Int      @default(0)
  viewsCount  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  likes       ReelLike[]

  @@index([userId])
  @@index([productId])
  @@index([isActive, createdAt])
}

model ReelLike {
  id        String   @id @default(cuid())
  reelId    String
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, reelId])
  @@index([reelId])
}

// ─── Service Model ─────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  vendorId    String?
  vendor      VendorProfile? @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name        String
  description String
  price       Decimal
  priceDisplay String?  // e.g. "From GH₵ 50" or "GH₵ 0.50/pg"
  imageUrl    String
  category    String
  rating      Decimal    @default(0)
  ratingCount Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vendorId])
  @@index([category])
  @@index([isActive])
}
