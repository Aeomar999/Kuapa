{
  "expo": {
    "name": "Kuapa",
    "slug": "kuapa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kuapa",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bexiemart.app",
      "associatedDomains": [
        "applinks:bexiemart.com"
      ],
      "config": {
        "googleMapsApiKey": "REPLACE_WITH_GOOGLE_MAPS_IOS_KEY"
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of products to sell on Kuapa.",
        "NSPhotoLibraryUsageDescription": "Select product images from your photo library.",
        "NSLocationWhenInUseUsageDescription": "Kuapa needs your location to track deliveries and riders."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-adaptive-foreground.png",
        "backgroundColor": "#F8F4EA"
      },
      "package": "com.bexiemart.app",
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_GOOGLE_MAPS_ANDROID_KEY"
        }
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "bexiemart.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "bexiemart",
              "host": "verify-email"
            },
            {
              "scheme": "bexiemart",
              "host": "reset-password"
            },
            {
              "scheme": "bexiemart",
              "host": "auth"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kuapa needs your location to track deliveries and match you with nearby riders."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B5233",
          "image": "./assets/images/icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Select product images for your Kuapa listings.",
          "cameraPermission": "Take photos of your products for Kuapa."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableEdgeToEdge": true,
            "newArchEnabled": true,
            "enablePngCrunchInReleaseBuilds": false
          },
          "ios": {
            "useFrameworks": "static",
            "newArchEnabled": true
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "kreddible",
          "project": "bexiemart-mobile"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a830e794-6932-47fd-9779-9b1317c59f3f"
      }
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 10000,
      "url": "https://u.expo.dev/a830e794-6932-47fd-9779-9b1317c59f3f"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "amoahjerry835"
  }
}
