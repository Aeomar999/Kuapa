{
  "expo": {
    "name": "BexieMart",
    "slug": "bexiemart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bexiemart",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bexiemart.app",
      "associatedDomains": ["applinks:bexiemart.com"],
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of products to sell on BexieMart.",
        "NSPhotoLibraryUsageDescription": "Select product images from your photo library.",
        "NSLocationWhenInUseUsageDescription": "BexieMart needs your location to track deliveries and riders."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-adaptive-foreground.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.bexiemart.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "bexiemart.com", "pathPrefix": "/" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            { "scheme": "bexiemart", "host": "verify-email" },
            { "scheme": "bexiemart", "host": "reset-password" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#004CFF",
          "image": "./assets/images/icon.png",
          "imageWidth": 200

        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Select product images for your BexieMart listings.",
          "cameraPermission": "Take photos of your products for BexieMart."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableEdgeToEdge": true,
            "newArchEnabled": true
          },
          "ios": {
            "useFrameworks": "static",
            "newArchEnabled": true
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "kreddible",
          "project": "bexiemart-mobile"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a830e794-6932-47fd-9779-9b1317c59f3f"
      }
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 10000,
      "url": "https://u.expo.dev/a830e794-6932-47fd-9779-9b1317c59f3f"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}