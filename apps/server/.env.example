# Server Environment Variables
# Copy this to .env and fill in the appropriate values.

# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:8081
# Comma-separated list of allowed CORS origins (defaults to dev origins if unset)
CORS_ORIGIN=http://localhost:3001,https://admin.bexiemart.com
# Dev only: rewrite "localhost" in verification email links to a LAN-reachable
# host (e.g. your machine's IP) so a physical device can open them. Leave unset
# in production.
DEV_EMAIL_HOST=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bexiemart

# Authentication (Better-Auth)
BETTER_AUTH_SECRET=your_long_random_auth_secret_here
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret


# Payments (Paystack)
PAYSTACK_SECRET_KEY=sk_test_...

# Sentry
SENTRY_DSN=your_server_sentry_dsn
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Optional Integrations
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Google Maps Platform (Routes API + Geocoding API) — server-side key.
# Restrict by API + IP in Google Cloud Console. Used for delivery distance,
# ETA, and route polyline pricing. If unset, the server falls back to a
# Haversine straight-line estimate so local dev still works.
GOOGLE_MAPS_API_KEY=

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email
SMTP_PASS=your_smtp_password
EMAIL_FROM="BexieMart <your_email>"

# Arkesel SMS Configuration
ARKESEL_API_KEY=your_arkesel_api_key_here
ARKESEL_SENDER_ID=BexieMart
