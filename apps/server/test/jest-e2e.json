{
  "moduleFileExtensions": ["js", "json", "ts", "mjs"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest",
    "^.+\\.mjs$": ["ts-jest", { "useESM": true }]
  },
  "transformIgnorePatterns": [],
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/__mocks__/uuid",
    "^better-auth$": "<rootDir>/__mocks__/better-auth",
    "^better-auth/adapters/prisma$": "<rootDir>/__mocks__/better-auth",
    "^better-auth/plugins$": "<rootDir>/__mocks__/better-auth",
    "^better-auth/node$": "<rootDir>/__mocks__/better-auth",
    "^@better-auth/infra$": "<rootDir>/__mocks__/@better-auth/infra"
  }
}
