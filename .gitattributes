# Normalize line endings to LF for all text files. The Prettier config enforces
# LF, so without this a Windows checkout (CRLF) flips every line back and forth
# and produces huge, noisy "whitespace-only" diffs.
* text=auto eol=lf

# Windows scripts must keep CRLF or they break.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Treat common binary assets as binary so Git never munges EOLs or tries to diff them.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.svg      text
*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary
*.pdf      binary
*.keystore binary
*.jks      binary
*.mp4      binary
*.mov      binary
